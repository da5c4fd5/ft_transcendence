generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────
// Auth
// ─────────────────────────────────────────────────────────────

/// Server-side session used for token revocation on logout.
model Session {
  id        String   @id @default(cuid())
  userId    String
  userAgent String?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

// ─────────────────────────────────────────────────────────────
// Users
// ─────────────────────────────────────────────────────────────

model User {
  id                   String    @id @default(cuid())
  email                String    @unique
  emailVerifiedAt      DateTime?
  emailVerificationCodeHash String? @db.Text
  emailVerificationExpiresAt DateTime?
  emailVerificationSentAt DateTime?
  passwordHash         String
  username             String    @unique
  displayName          String?
  avatarUrl            String?
  /// JSON blob: { emailDigest, pushEnabled, reminderTime }
  notificationSettings Json      @default("{}")
  /// JSON blob for the gamification tree state
  treeState            Json      @default("{}")
  lastActiveAt         DateTime?
  isAdmin              Boolean   @default(false)
  publicApiKeyHash     String?   @unique @db.Text
  publicApiKeyPreview  String?   @db.VarChar(64)
  publicApiKeyCreatedAt DateTime?
  /// Encrypted TOTP secret (AES-256-GCM). Null = MFA not enabled.
  mfaSecret            String?   @db.Text
  /// Encrypted TOTP secret during the setup flow. Cleared once verify completes.
  mfaPendingSecret     String?   @db.Text
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  sessions      Session[]
  sentRequests  Friend[]       @relation("Requester")
  recvRequests  Friend[]       @relation("Recipient")
  memories      Memory[]
  contributions Contribution[]
  promptSuggestionState PromptSuggestionState? @relation("UserPromptSuggestionState")
  promptSuggestions     PromptSuggestion[]
  moodClassificationJobs MoodClassificationJob[]

  @@map("users")
}

// ─────────────────────────────────────────────────────────────
// Friends
// ─────────────────────────────────────────────────────────────

enum FriendStatus {
  PENDING
  ACCEPTED
}

model Friend {
  id          String       @id @default(cuid())
  requesterId String
  recipientId String
  status      FriendStatus @default(PENDING)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  requester User @relation("Requester", fields: [requesterId], references: [id], onDelete: Cascade)
  recipient User @relation("Recipient", fields: [recipientId], references: [id], onDelete: Cascade)

  @@unique([requesterId, recipientId])
  @@index([recipientId])
  @@map("friends")
}

// ─────────────────────────────────────────────────────────────
// Memories
// ─────────────────────────────────────────────────────────────

model Memory {
  id        String   @id @default(cuid())
  userId    String
  content   String   @db.Text
  /// The calendar day this memory belongs to (time portion is ignored)
  date      DateTime @default(now()) @db.Date
  mood      String?  @db.VarChar(32)
  moodSource MemoryMoodSource?
  /// When true, anyone with the link can add a contribution
  isOpen     Boolean  @default(false)
  /// Unique token used for share links. Generated when isOpen is set to true.
  shareToken String?  @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  media         Media[]
  contributions Contribution[]
  moodClassificationJob MoodClassificationJob?

  @@index([userId, date(sort: Desc)])
  @@map("memories")
}

model Media {
  id        String   @id @default(cuid())
  memoryId  String
  url       String
  mimeType  String   @db.VarChar(128)
  createdAt DateTime @default(now())

  memory Memory @relation(fields: [memoryId], references: [id], onDelete: Cascade)

  @@index([memoryId])
  @@map("media")
}

// ─────────────────────────────────────────────────────────────
// Contributions
// ─────────────────────────────────────────────────────────────

model Contribution {
  id            String   @id @default(cuid())
  memoryId      String
  /// Null when the contributor is a guest (not signed in)
  contributorId String?
  guestName     String?  @db.VarChar(64)
  guestAvatarUrl String? @db.Text
  content       String   @db.Text
  mediaUrl      String?  @db.Text
  createdAt     DateTime @default(now())

  memory      Memory @relation(fields: [memoryId], references: [id], onDelete: Cascade)
  contributor User?  @relation(fields: [contributorId], references: [id], onDelete: SetNull)

  @@index([memoryId])
  @@map("contributions")
}

enum PromptSuggestionStatus {
  IDLE
  GENERATING
  READY
  ERROR
}

enum MemoryMoodSource {
  MANUAL
  CLASSIFIED
}

enum MoodClassificationJobStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

model MoodClassificationJob {
  id              String                      @id @default(cuid())
  memoryId        String                      @unique
  userId          String
  content         String                      @db.Text
  status          MoodClassificationJobStatus @default(QUEUED)
  attempts        Int                         @default(0)
  availableAt     DateTime                    @default(now())
  startedAt       DateTime?
  finishedAt      DateTime?
  classifierModel String?                     @db.VarChar(128)
  rawLabel        String?                     @db.VarChar(64)
  rawScore        Float?
  mood            String?                     @db.VarChar(32)
  labelsJson      Json?
  lastError       String?                     @db.Text
  createdAt       DateTime                    @default(now())
  updatedAt       DateTime                    @updatedAt

  memory Memory @relation(fields: [memoryId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, availableAt, createdAt])
  @@index([userId, createdAt(sort: Desc)])
  @@map("mood_classification_jobs")
}

model PromptSuggestionState {
  userId               String                 @id
  contextHash          String?
  generationToken      String?
  model                String?                @db.VarChar(128)
  systemPrompt         String?                @db.Text
  requestPrompt        String?                @db.Text
  generationStatus     PromptSuggestionStatus @default(IDLE)
  lastError            String?                @db.Text
  expiresAt            DateTime?
  generationStartedAt  DateTime?
  generationFinishedAt DateTime?
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt

  user User @relation("UserPromptSuggestionState", fields: [userId], references: [id], onDelete: Cascade)

  @@map("prompt_suggestion_states")
}

model PromptSuggestion {
  id        String   @id @default(cuid())
  userId    String
  prompt    String   @db.Text
  position  Int
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, position])
  @@index([userId, position])
  @@map("prompt_suggestions")
}
