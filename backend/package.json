{
  "name": "capsul-api",
  "version": "0.1.0",
  "main": "./src/index.ts",
  "scripts": {
    "start": "bun src/index.ts",
    "dev": "bun --hot src/index.ts",
    "db:generate": "bun --bun run prisma generate",
    "db:migrate": "bun --bun run prisma migrate dev",
    "db:migrate:prod": "bun --bun run prisma migrate deploy",
    "db:reset": "bun --bun run prisma migrate reset",
    "db:seed": "bun prisma/seed.ts",
    "db:studio": "bun --bun run prisma studio"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/jwt": "^1.4.1",
    "@elysiajs/swagger": "^1.3.1",
    "@paralleldrive/cuid2": "^3.3.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@types/bun": "^1.3.11",
    "@types/jsonwebtoken": "^9.0.10",
    "dotenv": "^17.4.1",
    "elysia": "^1.4.28",
    "jsonwebtoken": "^9.0.3",
    "otplib": "^13.4.0",
    "pg": "^8.20.0",
    "prisma": "^7.6.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "prettier": "^3.8.1",
    "pretty-quick": "^4.2.2",
    "simple-git-hooks": "^2.13.1"
  }
}
