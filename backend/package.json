{
  "name": "transcendence-api",
  "version": "0.1.0",
  "main": "./src/index.ts",
  "scripts": {
    "start": "bun src/index.ts",
    "db:generate": "bun --bun run prisma generate",
    "db:migrate": "bun --bun run prisma migrate dev",
    "db:migrate:prod": "bun --bun run prisma migrate deploy",
    "db:reset": "bun --bun run prisma migrate reset",
    "db:studio": "bun --bun run prisma studio"
  },
  "dependencies": {
    "@elysiajs/jwt": "^1.4.1",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@types/bun": "^1.3.11",
    "dotenv": "^17.4.1",
    "elysia": "^1.4.28",
    "pg": "^8.20.0",
    "prisma": "^7.6.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/pg": "^8.20.0"
  }
}
